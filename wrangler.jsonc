{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apoy",
  "main": "worker/apoy.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "TURSO_DATABASE_URL": "libsql://apoy-enigmatic-aquarius-tehb9z.aws-us-east-1.turso.io"
  }
}
